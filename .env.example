# Copy to .env.local and fill in. .env.local is gitignored — never commit real values.

# Client config (safe to expose — publishable/anon key + project URL)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional: Sentry error monitoring. Leave blank to disable. The DSN is a public
# client key (safe to ship), like the Supabase anon key.
VITE_SENTRY_DSN=

# Only used by scripts/smoke-test.js (a server-side data-layer test). Keep private.
SMOKE_EMAIL=you@example.com
SMOKE_PASSWORD=your-supabase-user-password
